# ============================================
# vps_primary 主机变量配置 (Sample)
# ============================================

# --- 1. 连接与认证 (Ansible 核心变量) ---
ansible_user: "root"

# 指向 keys/ 目录下的私钥文件
ansible_ssh_private_key_file: "keys/vps_primary_key"

# --- 2. 基础安全配置 ---
ssh_port: 9929                          # 部署后修改的自定义 SSH 端口

# --- 3. 域名与 Web 规划 ---
domain: "your-domain.com"
email: "your-email@example.com"
web_root: "/var/www/{{ domain }}"
ssl_cert_dir: "/etc/letsencrypt/live"
shared_data_dir: "/var/www/downloads"   # Aria2/WebDAV 共享存储路径
xray_path_url: "xray_sec_dl"            # Xray 客户端配置下载的隐藏 URL 路径

# --- 4. 服务运行用户 ---
vpn_user: "xray"                        # Xray 运行账户
vpn_group: "xray"                       # Xray 运行组
# --- 5. 业务逻辑与内部端口 ---
swap_size_mb: 2048                      # 虚拟内存大小
aria2_internal_port: 6800               # Aria2 RPC 端口
xray_internal_port: 10086               # Xray 内部监听端口
vpn_service_name: "xray"                # Xray 服务名称

# --- 6. 系统参数 ---
server_timezone: "America/Vancouver"    # 系统时区

# --- 7. WebDAV 专用变量 ---
webdav_htpasswd_path: "/etc/nginx/.htpasswd_webdav"
# 已统一：必须使用 webdav_footer_name 才能匹配 site.conf.j2 模板引用
webdav_footer_name: "webdav_footer.html"

# --- 8. Yattee 视频服务 ---
yattee_internal_port: 8085                    # yattee-server 容器内部端口
yattee_install_dir: "/opt/yattee-server"      # 源码与容器部署目录
yattee_admin_user: "admin"                    # Yattee 管理员用户名
yattee_domain: "yatee.your-domain.com"        # Yattee 子域名

# --- 9. Nginx 内部端口 ---
nginx_internal_https_port: 4433               # Nginx HTTPS 内部监听端口 (供 Stream SNI 分流转发)
