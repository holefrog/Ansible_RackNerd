# v2 - Ansible 托管，勿手动修改
# yattee 子域名 HTTP → HTTPS 重定向
server {
    listen 80;
    server_name {{ yattee_domain }};
    return 301 https://$host$request_uri;
}

# yattee 子域名 HTTPS server (与主站共用内部端口，按 server_name 区分)
server {
    listen {{ nginx_internal_https_port }} ssl http2;
    server_name {{ yattee_domain }};

    ssl_certificate {{ ssl_cert_dir }}/{{ yattee_domain }}/fullchain.pem;
    ssl_certificate_key {{ ssl_cert_dir }}/{{ yattee_domain }}/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:{{ yattee_internal_port }}/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header Connection "";
        proxy_buffering off;
        proxy_read_timeout 300s;
        client_max_body_size 100M;
    }

    location /static/ {
        proxy_pass http://127.0.0.1:{{ yattee_internal_port }}/static/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
    }

    location /favicon.ico {
        proxy_pass http://127.0.0.1:{{ yattee_internal_port }}/favicon.ico;
    }
}
