# v1 - Ansible 托管，勿手动修改
ADMIN_USERNAME={{ yattee_admin_user }}
ADMIN_PASSWORD={{ yattee_admin_password }}
SECRET_KEY={{ yattee_secret_key }}
SECURE_COOKIES=true

# YouTube 出口代理（VPS IP 被封时启用，格式：http://user:pass@host:port）
# YT_EGRESS_PROXY=

# 终极防封方案：使用公共 Invidious 实例代理所有请求（无需 Cookie，直接绕过机器验证）
# 如果遇到严重风控 (Sign in to confirm you're not a bot)，取消下方注释并重新启动容器：
INVIDIOUS_INSTANCE_URL=https://invidious.jing.rocks
