server {
    listen 80;
    server_name {{ domain }};
    return 301 https://$host$request_uri;
}

server {
    listen 4433 ssl http2;
    server_name {{ domain }};

    ssl_certificate {{ ssl_cert_dir }}/{{ domain }}/fullchain.pem;
    ssl_certificate_key {{ ssl_cert_dir }}/{{ domain }}/privkey.pem;

    # 大文件性能优化
    sendfile on;
    tcp_nopush on;
    client_max_body_size 0;

    # 默认兜底路由，修复内部子请求上下文丢失导致的 500 错误，并提升防扫描安全性
    location / {
        return 404;
    }
    # 动态加载分发式的 Location 配置文件 (供 vpn-xray 等组件注入)
    include /etc/nginx/conf.d/{{ domain }}.locations.d/*.conf;
}
